rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== USERS =====
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Cho phép user update profile HOẶC app update points/totalReturned khi verify OTP
      allow update: if request.auth != null 
                    && (request.auth.uid == userId
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'totalReturned']));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // ===== POSTS =====
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Cho phép owner update HOẶC app update status/resolvedAt/resolvedBy/rating/review khi verify OTP
      allow update: if request.auth != null 
                    && (request.auth.uid == resource.data.userId
                        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt', 'resolvedBy', 'rating', 'review']));
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // COMMENTS
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
      
      // REPORTS
      match /reports/{reportId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null;
      }
    }
    
    // ===== CHATS =====
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // ===== NOTIFICATIONS =====
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // ===== OTP CODES =====
    match /otpCodes/{otpId} {
      // User A tạo OTP (chủ bài lost)
      allow create: if request.auth != null 
                    && request.resource.data.lostUserId == request.auth.uid;
      
      // User A xóa OTP của mình
      allow delete: if request.auth != null 
                    && resource.data.lostUserId == request.auth.uid;
      
      // User B đọc OTP (để verify)
      allow read: if request.auth != null;
      
      // User B verify OTP (update verified = true)
      allow update: if request.auth != null 
                    && request.resource.data.verified == true
                    && resource.data.verified == false;
    }
    
    // ===== TRANSACTIONS =====
    match /transactions/{transactionId} {
      // Cho phép app tạo transaction khi verify OTP thành công
      allow create: if request.auth != null;
      
      // Cho phép user đọc transaction của mình
      allow read: if request.auth != null 
                  && resource.data.userId == request.auth.uid;
      
      // Không cho phép update hoặc delete transaction
      allow update, delete: if false;
    }
  }
}
