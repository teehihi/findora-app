## Example local.properties file
## Copy this file to local.properties and fill in your API keys

# Android SDK location (auto-generated)
sdk.dir=/path/to/android/sdk

# API Keys - DO NOT commit the actual local.properties file!
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Mapbox token (if needed)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Google Maps API key (if needed)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
