<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Green dot -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#22C55E" />
        </shape>
    </item>
    <!-- White border -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
