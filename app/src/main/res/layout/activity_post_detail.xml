<?xml version="1.0" encoding="utf-8"?>
<!-- 
  activity_post_detail.xml - Findora Post Details
  Premium Figma-accurate design.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Sticky Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="@color/background"
        android:elevation="8dp">

        <TextView
            android:id="@+id/btnContact"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_button_secondary_ios"
            android:gravity="center"
            android:text="@string/detail_contact_owner"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:textSize="16sp"
            android:drawableStart="@drawable/ic_person"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="8dp"
            app:drawableTint="@color/on_surface" />

        <TextView
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary_ios"
            android:gravity="center"
            android:text="@string/detail_chat"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:drawableStart="@drawable/ic_chat"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="8dp"
            app:drawableTint="@color/white" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomActions"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Image Area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp">

                <ImageView
                    android:id="@+id/ivDetailImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_img_placeholder"
                    android:scaleType="centerCrop" />

                <!-- Toolbar Layout -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingHorizontal="16dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_chevron_left"
                        android:background="@drawable/bg_ios_icon_btn"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="horizontal">
                        
                        <ImageButton
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_notifications" 
                            android:background="@drawable/bg_ios_icon_btn"
                            app:tint="@color/primary" />

                        <ImageButton
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_settings"
                            android:background="@drawable/bg_ios_icon_btn"
                            app:tint="@color/primary" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Badge positioned on the card part -->
                <TextView
                    android:id="@+id/tvDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="20dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp"
                    android:text="LOST"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_chip_active" />

            </FrameLayout>

            <!-- Main Content Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="40dp">

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="iPhone 13 – Blue Case"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvDetailTimeHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Posted 30 minutes ago"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="4dp" />

                <!-- Description Heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lost near the central park playground around 4 PM. It has a blue silicone case and a cracked screen protector."
                    android:textSize="15sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

                <!-- Info Cards (Time/Category) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:padding="16dp"
                        android:background="@drawable/bg_card_info"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_notifications" 
                            app:tint="@color/primary" />
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TIME"
                                android:textSize="10sp"
                                android:textColor="@color/outline"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvInfoTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today, 4:00 PM"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="16dp"
                        android:background="@drawable/bg_card_info"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_nav_home_inactive"
                            app:tint="@color/primary" />
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CATEGORY"
                                android:textSize="10sp"
                                android:textColor="@color/outline"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvInfoCategory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Electronics"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Location Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/tvDetailLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Central Park, NYC"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Map Placeholder -->
                <ImageView
                    android:id="@+id/ivMapPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_img_placeholder"
                    android:src="@drawable/recent_activity_bg" />

                <!-- User Profile Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_person"
                        android:padding="8dp"
                        android:background="@drawable/bg_ios_icon_btn"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marcus Thompson"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />
                        <TextView
                            android:id="@+id/tvUserStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active 5m ago • Verified Owner"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/outline" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
