<?xml version="1.0" encoding="utf-8"?>
<!-- 
  activity_post_detail.xml - Findora Post Details
  Precisely styled to match the Stitch Figma Design.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7"
    android:fitsSystemWindows="true"> <!-- Light gray screen background -->

    <!-- Sticky Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="#FFFFFF"
        android:elevation="0dp">

        <TextView
            android:id="@+id/btnContact"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_btn_outline_ios"
            android:gravity="center"
            android:text="Liên hệ"
            android:textColor="#22C55E"
            android:textStyle="bold"
            android:textSize="16sp"
            android:drawableStart="@drawable/ic_person"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:drawablePadding="-8dp"
            app:drawableTint="#22C55E" />

        <TextView
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary_ios"
            android:gravity="center"
            android:text="Trò chuyện"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:drawableStart="@drawable/ic_chat"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:drawablePadding="-8dp"
            app:drawableTint="@color/white" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomActions"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Area: Image bleeding under Toolbar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Image Area -->
                <!-- Spans full width and height of the FrameLayout, sits under toolbar -->
                <ImageView
                    android:id="@+id/ivDetailImage"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:src="@drawable/bg_img_placeholder"
                    android:scaleType="centerCrop" />

                <!-- Toolbar Layout (Floating on top of image) -->
                <RelativeLayout
                    android:id="@+id/detailToolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:paddingHorizontal="24dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_chevron_left"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:background="@drawable/bg_circle_white"
                        android:elevation="6dp"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="horizontal">
                        
                        <ImageButton
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_share" 
                            android:padding="12dp"
                            android:scaleType="fitCenter"
                            android:background="@drawable/bg_circle_white"
                            android:elevation="6dp"
                            app:tint="@color/primary" />

                        <ImageButton
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_more_vert"
                            android:padding="12dp"
                            android:scaleType="fitCenter"
                            android:background="@drawable/bg_circle_white"
                            android:elevation="6dp"
                            app:tint="@color/primary" />
                    </LinearLayout>
                </RelativeLayout>
            </FrameLayout>

            <!-- Main White Card overlapping the image slightly -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-30dp"
                android:background="@drawable/bg_rounded_top_white"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="40dp">

                <!-- Badge -->
                <TextView
                    android:id="@+id/tvDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="MẤT"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_badge_lost" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="iPhone 13 – Blue Case"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/on_surface" />

                <!-- Posted Time Header -->
                <TextView
                    android:id="@+id/tvDetailTimeHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đăng lúc 30 phút trước"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="6dp" />

                <!-- Description Heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả chi tiết"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lost near the central park playground around 4 PM..."
                    android:textSize="15sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="6dp" />

                <!-- Info Cards (Time & Category) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="28dp">

                    <!-- Time Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:paddingVertical="18dp"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_info_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_time_circle" 
                            android:padding="2dp"
                            app:tint="@color/primary" />
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="THỜI GIAN"
                                android:textSize="10sp"
                                android:textColor="@color/outline"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvInfoTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Hôm nay, 16:00"
                                android:textSize="12sp"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Category Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="18dp"
                        android:paddingHorizontal="16dp"
                        android:background="@drawable/bg_info_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_category_shapes"
                            android:padding="2dp"
                            app:tint="@color/primary" />
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DANH MỤC"
                                android:textSize="10sp"
                                android:textColor="@color/outline"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tvInfoCategory"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Đồ điện tử"
                                android:textSize="12sp"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Location Header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Khu vực"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />
                
                <TextView
                    android:id="@+id/tvDetailLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Central Park, NYC"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <!-- Map Placeholder (Rounded) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cvMapPreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    
                    <com.mapbox.maps.MapView
                        android:id="@+id/mapViewDetail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                    
                    <!-- Fallback image if no location -->
                    <ImageView
                        android:id="@+id/ivMapPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/recent_activity_bg"
                        android:visibility="gone" />
                </androidx.cardview.widget.CardView>

                <!-- User Profile Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_info_card"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_person"
                        android:padding="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marcus Thompson"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />
                        <TextView
                            android:id="@+id/tvUserStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vừa truy cập • Đã xác thực"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant" 
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/outline" />
                </LinearLayout>

            </LinearLayout>

            <!-- Like & Comment Section -->
            <include layout="@layout/section_like_comment" />

            <!-- Continue with Smart Matches in main card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="40dp">

                <!-- Smart Matches Section -->
                <LinearLayout
                    android:id="@+id/layoutSmartMatchesTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gợi ý ghép cặp thông minh"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Các bài đăng có độ rủi ro khớp cao dựa trên AI"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbSmartMatches"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tvNoSmartMatches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Không tìm thấy gợi ý phù hợp lúc này."
                    android:textAlignment="center"
                    android:textColor="@color/outline"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSmartMatches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
