<?xml version="1.0" encoding="utf-8"?>
<!-- Section Like & Comment cho PostDetailActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp"
    android:layout_marginTop="12dp">

    <!-- Like & Comment Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <!-- Like Button -->
        <ImageButton
            android:id="@+id/btnLike"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_like_selector"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like" />

        <TextView
            android:id="@+id/tvLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Comment Icon -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_comment_feather"
            android:tint="@color/text_secondary"
            android:contentDescription="Comments" />

        <TextView
            android:id="@+id/tvCommentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

    </LinearLayout>
    
    <!-- Border line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant" />

    <!-- Comments List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:nestedScrollingEnabled="false" />

    <!-- Comment Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Viết bình luận..."
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:background="@drawable/bg_search_field"
            android:padding="12dp"
            android:maxLines="3"
            android:inputType="textMultiLine|textCapSentences" />

        <ImageButton
            android:id="@+id/btnSendComment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/primary"
            android:layout_marginStart="8dp"
            android:contentDescription="Gửi" />

    </LinearLayout>

</LinearLayout>
