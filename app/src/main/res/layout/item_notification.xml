<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon Container -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp">

        <!-- Background Circle -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_light_blue" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/ivNotificationIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_notifications"
            android:contentDescription="@string/notification_icon" />

        <!-- Avatar (for message notifications) -->
        <ImageView
            android:id="@+id/ivNotificationAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:contentDescription="@string/user_avatar" />

    </FrameLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thông báo"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Body -->
        <TextView
            android:id="@+id/tvNotificationBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nội dung thông báo"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="normal"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Time -->
        <TextView
            android:id="@+id/tvNotificationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 giờ trước"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:textStyle="normal"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Unread Indicator -->
    <View
        android:id="@+id/viewUnreadIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_unread_dot"
        android:visibility="visible" />

</LinearLayout>
