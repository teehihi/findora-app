<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/ivMyPostImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_img_placeholder" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <!-- Badge & Time -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvMyPostBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOST"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#DC2626"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_badge_lost"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/tvMyPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="2 hours ago"
                        android:textSize="11sp"
                        android:textColor="@color/outline" />
                </RelativeLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvMyPostTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="iPhone 14 Pro Max"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/on_surface"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_on"
                        app:tint="@color/outline" />
                        
                    <TextView
                        android:id="@+id/tvMyPostLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="District 1, HCM City"
                        android:textSize="13sp"
                        android:textColor="@color/outline"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_btn_outline_ios"
                android:gravity="center"
                android:text="@string/my_posts_btn_edit"
                android:textColor="#22C55E"
                android:textStyle="bold"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_edit_ios"
                android:paddingStart="24dp"
                android:paddingEnd="16dp"
                android:drawablePadding="-12dp"
                app:drawableTint="#22C55E" />

            <TextView
                android:id="@+id/btnResolved"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_primary_ios"
                android:gravity="center"
                android:text="@string/my_posts_btn_resolved"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_check_circle"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:drawablePadding="-12dp"
                app:drawableTint="@color/white" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
