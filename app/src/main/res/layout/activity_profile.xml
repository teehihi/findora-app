<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="88dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ═══════════════════════════════════════ -->
                <!-- TASK 1: Hero Profile Section + Level Badge -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="24dp"
                    android:gravity="center_horizontal">

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar_border" />

                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_user_feather"
                            android:background="@drawable/bg_ios_icon_btn"
                            android:scaleType="centerCrop" />

                    </FrameLayout>

                    <!-- Username -->
                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alex Rivera"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <!-- TASK 1: Level Badge (replaces email) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_level_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:id="@+id/ivLevelIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_newbie"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvLevelBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Người mới"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#15803D" />

                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/btnEditProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:text="@string/profile_edit"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:background="@drawable/bg_profile_button"
                            android:gravity="center"
                            android:paddingHorizontal="24dp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/btnShareProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/profile_share"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:background="@drawable/bg_chip_inactive"
                            android:gravity="center"
                            android:paddingHorizontal="24dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- TASK 2: Stats Card (3 columns) -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_stats_card">

                    <!-- Bài đăng -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvActivePosts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bài đăng"
                            android:textSize="11sp"
                            android:textColor="#71717A" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#E5E7EB"
                        android:layout_marginVertical="12dp" />

                    <!-- Đã trả -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvItemsReturned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đã trả lại"
                            android:textSize="11sp"
                            android:textColor="#71717A" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#E5E7EB"
                        android:layout_marginVertical="12dp" />

                    <!-- FindoPoint -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvFindoPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FindoPoint"
                            android:textSize="11sp"
                            android:textColor="#71717A" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- TASK 3: Tiện ích của tôi -->
                <!-- ═══════════════════════════════════════ -->

                <!-- Top divider (gray separator) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#F3F4F6"
                    android:layout_marginBottom="0dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp"
                    android:background="@color/surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiện ích của tôi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#171717"
                        android:layout_marginBottom="16dp" />

                    <!-- 4 items in 1 row, no border/radius per item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Bản đồ Findora -->
                        <LinearLayout
                            android:id="@+id/btnFindoraMap"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_findora_map"
                                android:scaleType="fitCenter"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bản đồ Findora"
                                android:textSize="11sp"
                                android:textColor="@color/on_surface"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Chợ Voucher -->
                        <LinearLayout
                            android:id="@+id/btnVoucherMarket"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_voucher_market"
                                android:scaleType="fitCenter"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chợ Voucher"
                                android:textSize="11sp"
                                android:textColor="@color/on_surface"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Bảng xếp hạng -->
                        <LinearLayout
                            android:id="@+id/btnLeaderboard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_leaderboard"
                                android:scaleType="fitCenter"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bảng xếp hạng"
                                android:textSize="11sp"
                                android:textColor="@color/on_surface"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <!-- Ví & Điểm -->
                        <LinearLayout
                            android:id="@+id/btnWallet"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_wallet"
                                android:scaleType="fitCenter"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ví &amp; Điểm"
                                android:textSize="11sp"
                                android:textColor="@color/on_surface"
                                android:gravity="center"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Bottom divider (gray separator) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#F3F4F6" />

                <!-- ═══════════════════════════════════════ -->
                <!-- TASK 4: Nâng cấp tài khoản Widget -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nâng cấp tài khoản"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#171717"
                        android:layout_marginBottom="14dp" />

                    <!-- Level-up Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_levelup_card"
                        android:padding="20dp"
                        android:gravity="center">

                        <!-- Circular Progress -->
                        <FrameLayout
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_marginBottom="16dp">

                            <!-- Background circle track -->
                            <ProgressBar
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:progressDrawable="@drawable/circular_progress_track"
                                android:progress="100"
                                android:rotation="-90" />

                            <!-- Actual progress -->
                            <ProgressBar
                                android:id="@+id/circularProgress"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:progressDrawable="@drawable/circular_progress_bar"
                                android:progress="0"
                                android:max="100"
                                android:rotation="-90" />

                            <!-- Percent text in center -->
                            <TextView
                                android:id="@+id/tvProgressPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="0%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#22C55E" />

                        </FrameLayout>

                        <!-- Description -->
                        <TextView
                            android:id="@+id/tvLevelUpDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đạt 100 GP (Green Points) để trở thành Cộng tác viên"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center"
                            android:layout_marginBottom="16dp" />

                        <!-- Upgrade Button -->
                        <LinearLayout
                            android:id="@+id/btnUpgrade"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_upgrade_btn"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_upgrade"
                                app:tint="#9CA3AF"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nâng cấp"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#9CA3AF" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- Account Overview Section -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_account_overview"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface_variant"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stats_card">

                        <!-- My Posts -->
                        <LinearLayout
                            android:id="@+id/btnMyPosts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="18dp"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_book_feather"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_my_posts"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/outline" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="58dp"
                            android:background="@color/outline_variant" />

                        <!-- Saved Items -->
                        <LinearLayout
                            android:id="@+id/btnSavedItems"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="18dp"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_bookmark_feather"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_saved_items"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/outline" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="58dp"
                            android:background="@color/outline_variant" />

                        <!-- Settings -->
                        <LinearLayout
                            android:id="@+id/btnSettings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="18dp"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_settings_feather"
                                android:layout_marginEnd="16dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_settings"
                                android:textSize="16sp"
                                android:textColor="@color/on_surface" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/outline" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Logout -->
                    <LinearLayout
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="18dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_logout_button"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_logout_feather"
                            app:tint="#B31B25"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_logout"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#B31B25" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:paddingTop="4dp"
        style="@style/BottomNavStyle"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@null"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreatePost"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white"
        app:elevation="0dp"
        app:fabSize="normal"
        app:maxImageSize="24dp"
        app:borderWidth="0dp"
        android:contentDescription="Đăng bài mới" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
