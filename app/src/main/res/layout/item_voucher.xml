<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white"
        android:gravity="center_vertical">

        <!-- Image Container with soft border -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_tab_container"
            android:padding="1dp">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgVoucher"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_img_placeholder"
                app:shapeAppearanceOverlay="@style/RoundedSmall" />
        </FrameLayout>

        <!-- Middle: Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtBrandName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thương hiệu"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/txtVoucherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tên Voucher giảm giá cực sốc"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/txtMetadata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Còn 10 • Hết hạn 31/12"
                android:textColor="#64748B"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Right: Points & CTA -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtVoucherPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 FP"
                android:textColor="@color/primary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRedeem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Thu thập"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="32dp"
                android:minWidth="84dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="20dp"
                app:elevation="0dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
