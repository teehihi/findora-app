<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Stitch Design (Modern 2024)
  Ref: Home Screen mockup
  - Header: location + bell
  - Large heading "What are we finding today?" (finding = blue italic)
  - Search bar (gray rounded)
  - Filter chips: All Items (blue) | Lost | Found (outline)
  - AI Match card (teaser)
  - Section "Recent Reports"
  - RecyclerView post cards
  - FAB coral orange
  - Bottom navigation
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <!-- ===== Scrollable Content ===== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header: Location + Bell ── -->
            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location_pin"
                    app:tint="@color/primary"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/location_hcmc"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp" />

                <!-- Notification button with badge -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">
                    
                    <ImageButton
                        android:id="@+id/btnNotification"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_ios_icon_btn"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/on_surface_variant"
                        android:contentDescription="Notifications" />
                    
                    <!-- Badge -->
                    <TextView
                        android:id="@+id/tvNotificationBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_notification_badge"
                        android:gravity="center"
                        android:text="9"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />
                    
                </FrameLayout>
                
                <ImageButton
                    android:id="@+id/btnRefreshMatches"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ios_icon_btn"
                    android:src="@drawable/ic_refresh"
                    app:tint="@color/primary"
                    android:contentDescription="Tìm matches ngay" />

            </LinearLayout>

            <!-- ── Hero: Big Heading ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <!--
                  "What are we" — regular black
                  "finding" — blue bold italic (set via SpannableString in Java)
                  "today?" — regular black
                -->
                <TextView
                    android:id="@+id/tvHeading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_heading"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_search_field"
                    android:paddingHorizontal="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/outline"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="@string/search_hint"
                        android:textColorHint="@color/outline"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:background="@null"
                        android:inputType="text"
                        android:singleLine="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Filter Chips ── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/chip_all"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary"
                        android:background="@drawable/bg_chip_active"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chipLost"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/chip_lost"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_inactive"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chipFound"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/chip_found"
                        android:gravity="center"
                        android:paddingHorizontal="18dp"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_inactive" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- ── AI Match Assistant Card ── -->
            <LinearLayout
                android:id="@+id/layoutAICard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_ai_card"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Header row: icon + label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_ai_star"
                        app:tint="@color/primary"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="AI icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_assistant"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvAITitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_coming_soon"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvAIDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_description"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>

            <!-- ── Section Header: Recent Reports ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_reports"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/updated_now"
                        android:textSize="12sp"
                        android:textColor="@color/outline" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/explore_all"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <!-- ── Loading indicator ── -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="24dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- ── RecyclerView (post cards, với padding ngang) ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- ── Empty state ── -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="64dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/outline"
                    android:contentDescription="Search icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/empty_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/empty_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/outline"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ── Bottom Navigation Bar (Flat Design) ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:paddingTop="4dp"
        style="@style/BottomNavStyle"
        app:elevation="0dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@null"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled" />

    <!-- ── FAB: Center Post Button (Flat Design) ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreatePost"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white"
        app:elevation="0dp"
        app:fabSize="normal"
        app:maxImageSize="24dp"
        app:borderWidth="0dp"
        android:contentDescription="Đăng bài mới" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>