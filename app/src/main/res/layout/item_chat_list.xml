<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:paddingHorizontal="20dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/ivChatListAvatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_person"
        android:background="@drawable/bg_ios_icon_btn"
        android:scaleType="centerCrop" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChatListName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="User Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvChatListTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30"
                android:textSize="12sp"
                android:textColor="@color/outline" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvChatListLastMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tin nhắn mới nhất..."
            android:textSize="13sp"
            android:textColor="@color/on_surface_variant"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvChatListPostTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Về: Ví da màu nâu"
            android:textSize="11sp"
            android:textColor="@color/outline"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
