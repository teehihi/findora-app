<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Xác nhận trả đồ"
                android:textColor="#171717"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_close"
                android:tint="#71717A" />
        </RelativeLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Nhập mã xác nhận"
            android:textColor="#71717A"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Yêu cầu người nhận đồ cung cấp mã 4 số để xác nhận giao dịch"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />

        <!-- OTP Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etOtp1"
                android:layout_width="60dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_otp_input"
                android:fontFamily="monospace"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#171717"
                android:textSize="32sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOtp2"
                android:layout_width="60dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_otp_input"
                android:fontFamily="monospace"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#171717"
                android:textSize="32sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOtp3"
                android:layout_width="60dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_otp_input"
                android:fontFamily="monospace"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#171717"
                android:textSize="32sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOtp4"
                android:layout_width="60dp"
                android:layout_height="70dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_otp_input"
                android:fontFamily="monospace"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#171717"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Error Message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Mã không đúng. Vui lòng thử lại."
            android:textColor="#DC2626"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Xác nhận"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#22C55E"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
