<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chọn địa chỉ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn từng bước để xác định vị trí chính xác"
                android:textSize="14sp"
                android:textColor="@color/outline"
                android:layout_marginBottom="8dp" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Nhấn vào bản đồ để điều chỉnh vị trí nếu cần"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:layout_marginBottom="24dp" />

            <!-- Province/City -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tỉnh/Thành phố"
                android:textSize="13sp"
                android:textColor="@color/outline"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_variant"
                android:layout_marginBottom="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <AutoCompleteTextView
                        android:id="@+id/actvProvince"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:hint="Gõ để tìm hoặc chọn"
                        android:textSize="16sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:completionThreshold="1"
                        android:dropDownHeight="300dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:contentDescription="Dropdown" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- District -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quận/Huyện"
                android:textSize="13sp"
                android:textColor="@color/outline"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_variant"
                android:layout_marginBottom="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <AutoCompleteTextView
                        android:id="@+id/actvDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:hint="Gõ để tìm hoặc chọn"
                        android:textSize="16sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:enabled="false"
                        android:completionThreshold="1"
                        android:dropDownHeight="300dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:contentDescription="Dropdown" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ward -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phường/Xã"
                android:textSize="13sp"
                android:textColor="@color/outline"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_variant"
                android:layout_marginBottom="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <AutoCompleteTextView
                        android:id="@+id/actvWard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="48dp"
                        android:hint="Gõ để tìm hoặc chọn"
                        android:textSize="16sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:enabled="false"
                        android:completionThreshold="1"
                        android:dropDownHeight="300dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:contentDescription="Dropdown" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Street Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số nhà, tên đường (không bắt buộc)"
                android:textSize="13sp"
                android:textColor="@color/outline"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_variant"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStreetAddress"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:paddingHorizontal="16dp"
                    android:hint="VD: 123 Nguyễn Huệ"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/outline"
                    android:background="@android:color/transparent"
                    android:inputType="textPostalAddress"
                    android:maxLines="1" />
            </androidx.cardview.widget.CardView>

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sau khi chọn xong, bạn sẽ xem vị trí trên bản đồ để xác nhận"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnViewOnMap"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Xem trên bản đồ"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_submit"
            app:backgroundTint="@null" />
    </LinearLayout>

    <!-- Current Location FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCurrentLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="88dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:tint="@color/white"
        app:backgroundTint="@color/primary"
        android:contentDescription="Lấy vị trí hiện tại" />

</LinearLayout>
