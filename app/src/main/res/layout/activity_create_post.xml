<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_create_post.xml — Stitch Design (Modern 2024)
  Ref: Post Item Screen mockup
  - Header: Back arrow + "Post Item" + AI Assisted button
  - Image placeholder (big rounded orb/image)
  - Toggle: Lost / Found (Modern pills)
  - Inputs: Item Name, Category (Spinner/Dropdown), Description, Last Seen Location
  - Map preview (placeholder image)
  - Submit button: Terracotta brown
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/createPostRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ===== Modern Header ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/on_surface"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/create_post_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_ai_card"
            android:paddingHorizontal="12dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/post_ai_assisted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Image Upload Placeholder ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvImageUpload"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                
                <ImageView
                    android:id="@+id/ivImagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_img_placeholder"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_upload"
                    app:tint="@color/outline" />
            </androidx.cardview.widget.CardView>

            <!-- ── Toggle Lost/Found ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/btnLost"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_toggle_on"
                    android:layout_marginEnd="12dp">
                    
                    <ImageView
                        android:id="@+id/iconLost"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/primary"
                        android:layout_marginEnd="8dp" />
                    
                    <TextView
                        android:id="@+id/tvLost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_type_lost"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFound"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_toggle_off">
                    
                    <ImageView
                        android:id="@+id/iconFound"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/outline"
                        android:layout_marginEnd="8dp" />
                    
                    <TextView
                        android:id="@+id/tvFound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_type_found"
                        android:textColor="@color/outline" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Form Fields ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/post_item_name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_search_field"
                android:hint="@string/post_title_hint"
                android:paddingHorizontal="16dp"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/post_description_label"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_search_field"
                android:hint="@string/post_description_hint"
                android:padding="16dp"
                android:gravity="top"
                android:textSize="15sp"
                android:layout_marginBottom="24dp" />

            <!-- ── Action Button ── -->
            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/post_submit"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_submit"
                app:backgroundTint="@null"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/post_agreement"
                android:textSize="12sp"
                android:textColor="@color/outline"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
